<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bhspl.syncagent</string>
    <key>ProgramArguments</key>
    <array>
        <string>java</string>
        <string>-jar</string>
        <string>{INSTALL_DIR}/target/attendance-sync-agent.jar</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>{INSTALL_DIR}</string>
    <key>StandardOutPath</key>
    <string>{INSTALL_DIR}/target/sync_agent_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>{INSTALL_DIR}/target/sync_agent_stderr.log</string>
</dict>
</plist>
